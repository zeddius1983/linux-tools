# Format: type:name[:Display Name]
# app     - export container .desktop entry to host menu
# bin     - export binary to ~/.local/bin
# desktop - create terminal-launched shortcut (place icon.png here for icon)
# gui     - create non-terminal shortcut for GUI apps
bin:amdgpu_top
desktop:amdgpu_top:amdgpu_top
gui:amdgpu_top-gui:amdgpu_top GUI
